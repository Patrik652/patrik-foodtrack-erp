<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodTrack.Mobile.Views.ScanPage"
             Title="Scan">
    <ScrollView BackgroundColor="#F6EFE5">
        <VerticalStackLayout Padding="20"
                             Spacing="16">
            <Label Text="Rýchle skladové akcie"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#1E2E1F" />
            <Label Text="Scan tab funguje ako operátorsky hub pre príjem, FIFO dispatch, inventúru a rýchly návrat do inventory dashboardu."
                   TextColor="#6B6258" />
            <Border Padding="18"
                    BackgroundColor="#FFF9F2"
                    Stroke="#E4C8A8"
                    StrokeShape="RoundRectangle 22">
                <VerticalStackLayout Spacing="12">
                    <Button Text="Nový príjem"
                            Clicked="OnReceiveClicked" />
                    <Button Text="FIFO expedícia"
                            Clicked="OnDispatchClicked" />
                    <Button Text="Inventúrna úprava"
                            Clicked="OnAdjustClicked" />
                    <Button Text="Otvoriť inventory list"
                            Clicked="OnInventoryClicked" />
                    <Button Text="Expiračný dashboard"
                            Clicked="OnDashboardClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
